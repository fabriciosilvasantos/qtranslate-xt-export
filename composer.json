{
  "name": "qtranslate/qtranslate-xt-export",
  "description": "qTranslate-XT (Exportação): Adds user-friendly multilingual content support, stored in single post.",
  "type": "wordpress-plugin",
  "keywords": [
    "wordpress",
    "wordpress-plugin",
    "qtranslate-x",
    "qtranslate-xt",
    "i18n"
  ],
  "homepage": "https://github.com/qtranslate/qtranslate-xt",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "qTranslate Community",
      "homepage": "https://github.com/qtranslate/qtranslate-xt/graphs/contributors"
    },
    {
      "name": "herrvigg",
      "role": "Developer: qTranslate-XT"
    },
    {
      "name": "johnclause",
      "role": "Developer: qTranslate-X"
    },
    {
      "name": "Qian Qin (chineseleper)",
      "role": "Developer: qTranslate"
    },
    {
      "name": "funkjedi",
      "role": "Developer: ACF for -X"
    },
    {
      "name": "Vavooon"
    },
    {
      "name": "grafcom"
    }
  ],
  "support": {
    "issues": "https://github.com/qtranslate/qtranslate-xt/issues",
    "wiki": "https://github.com/qtranslate/qtranslate-xt/wiki",
    "source": "https://github.com/qtranslate/qtranslate-xt"
  },
  "require": {
    "composer/installers": ">=1.0",
    "php": ">=8.4",
    "ext-intl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "squizlabs/php_codesniffer": "^3.8",
    "phpstan/phpstan": "^1.10",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "wp-coding-standards/wpcs": "^3.0",
    "yoast/phpunit-polyfills": "^2.0",
    "phpunit/php-code-coverage": "^9.2"
  },
  "autoload": {
    "psr-4": {
      "QTX\\": "src/classes/"
    }
  },
  "extra": {
    "installer-name": "qtranslate-xt"
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
